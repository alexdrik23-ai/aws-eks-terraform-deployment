# ─────────────────────────────────────────────────────────────────────────────
# terraform.tfvars.example
#
# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is git-ignored and should NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────────────────

aws_region   = "us-east-1"
project_name = "my-project"
environment  = "dev"   # dev | staging | prod

# ── VPC / Networking ─────────────────────────────────────────────────────────

vpc_cidr = "10.0.0.0/16"

availability_zones = [
  "us-east-1a",
  "us-east-1b",
  "us-east-1c",
]

private_subnet_cidrs = [
  "10.0.1.0/24",
  "10.0.2.0/24",
  "10.0.3.0/24",
]

public_subnet_cidrs = [
  "10.0.101.0/24",
  "10.0.102.0/24",
  "10.0.103.0/24",
]

enable_nat_gateway = true
single_nat_gateway = false   # set true in dev to save cost

# ── EKS Cluster ──────────────────────────────────────────────────────────────

cluster_name    = "my-eks-cluster"
cluster_version = "1.29"

cluster_endpoint_public_access       = true
cluster_endpoint_public_access_cidrs = ["0.0.0.0/0"]   # restrict in prod!

enable_cluster_encryption = false
# kms_key_arn             = "arn:aws:kms:us-east-1:123456789012:key/..."

# ── Node Group ───────────────────────────────────────────────────────────────

node_group_name    = "main"
node_instance_types = ["t3.medium"]
node_ami_type       = "AL2_x86_64"
node_disk_size      = 50
node_capacity_type  = "ON_DEMAND"   # ON_DEMAND | SPOT

node_desired_size = 2
node_min_size     = 1
node_max_size     = 5

# ── Add-ons ──────────────────────────────────────────────────────────────────

enable_aws_load_balancer_controller = false
enable_cluster_autoscaler           = false

# ── Additional Tags ──────────────────────────────────────────────────────────

additional_tags = {
  Team      = "platform"
  CostCenter = "engineering"
}
